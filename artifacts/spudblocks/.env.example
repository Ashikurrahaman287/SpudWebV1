# Public URL of the contact-form / admin API server.
# - Leave empty in dev (Replit) so /api calls hit the same origin.
# - On Vercel, set to the absolute origin of your API host
#   (e.g. https://api.spudblocks.com or your Replit deployment URL).
VITE_API_URL=

# Admin password used by the in-browser admin login. Must match the
# api-server's ADMIN_PASSWORD env var.
VITE_ADMIN_PASSWORD=spudblocks2024
