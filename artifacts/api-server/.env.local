# Local development database
# For quick local testing, use a free PostgreSQL service like:
# - Neon: https://neon.tech (free tier, no credit card required)
# - Railway: https://railway.app (free tier with limited resources)
# - Supabase: https://supabase.com (free tier with PostgreSQL)
# 
# Replace this with your actual DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/spudblocks

# Admin token - must match frontend's VITE_ADMIN_PASSWORD
ADMIN_PASSWORD=spudblocks2024

# Allow localhost during local development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# API Server Port
PORT=8080

# Optional: SendGrid configuration (not required for local testing)
# SENDGRID_API_KEY=your-key-here
# SENDGRID_FROM_EMAIL=noreply@spudblocks.com
# CONTACT_NOTIFICATION_EMAIL=admin@spudblocks.com
