# Postgres connection string used by Drizzle.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Admin token required by the x-admin-token header for admin endpoints.
# Must match the frontend's VITE_ADMIN_PASSWORD.
ADMIN_PASSWORD=spudblocks2024

# Comma-separated list of allowed CORS origins (no trailing slash).
# Leave empty in dev to allow any origin. In production, lock this down
# to your deployed frontend(s):
# CORS_ORIGINS=https://spudblocks.com,https://www.spudblocks.com
CORS_ORIGINS=

# Port the API server listens on (defaults to 8080).
PORT=8080

# Optional SendGrid notification config (all three required to enable).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# CONTACT_NOTIFICATION_EMAIL=
